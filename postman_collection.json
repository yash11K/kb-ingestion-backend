{
  "info": {
    "name": "AEM KB Ingestion System",
    "description": "API collection for the AEM Knowledge Base Ingestion System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000/api/v1"
    },
    {
      "key": "job_id",
      "value": ""
    },
    {
      "key": "file_id",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Ingestion",
      "item": [
        {
          "name": "Start Ingestion",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"url\": \"https://your-aem-instance/content/page.model.json\",\n  \"region\": \"US\",\n  \"brand\": \"YourBrand\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/ingest",
              "host": ["{{base_url}}"],
              "path": ["ingest"]
            },
            "description": "Start a new ingestion job. Returns 202 with job_id. The pipeline runs in the background."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 202) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.collectionVariables.set('job_id', jsonData.job_id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get Job Status",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/ingest/{{job_id}}",
              "host": ["{{base_url}}"],
              "path": ["ingest", "{{job_id}}"]
            },
            "description": "Get the status and counters for an ingestion job."
          }
        }
      ]
    },
    {
      "name": "Review Queue",
      "item": [
        {
          "name": "List Review Queue",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/queue?page=1&size=20",
              "host": ["{{base_url}}"],
              "path": ["queue"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "size", "value": "20" },
                { "key": "region", "value": "", "disabled": true },
                { "key": "brand", "value": "", "disabled": true },
                { "key": "content_type", "value": "", "disabled": true },
                { "key": "component_type", "value": "", "disabled": true }
              ]
            },
            "description": "List files pending human review. Enable query params to filter."
          }
        },
        {
          "name": "Get Queue Item Detail",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/queue/{{file_id}}",
              "host": ["{{base_url}}"],
              "path": ["queue", "{{file_id}}"]
            },
            "description": "Get full details for a file in the review queue. Returns 404 if not pending_review."
          }
        },
        {
          "name": "Accept File",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reviewed_by\": \"reviewer@example.com\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/queue/{{file_id}}/accept",
              "host": ["{{base_url}}"],
              "path": ["queue", "{{file_id}}", "accept"]
            },
            "description": "Approve a pending_review file. Triggers S3 upload in background."
          }
        },
        {
          "name": "Reject File",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reviewed_by\": \"reviewer@example.com\",\n  \"review_notes\": \"Content is too short and lacks context\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/queue/{{file_id}}/reject",
              "host": ["{{base_url}}"],
              "path": ["queue", "{{file_id}}", "reject"]
            },
            "description": "Reject a pending_review file with review notes."
          }
        },
        {
          "name": "Update File Content",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"md_content\": \"---\\ntitle: Updated Title\\ncontent_type: faq\\n---\\n# Updated content here\\n\\nThis is the revised body.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/queue/{{file_id}}/update",
              "host": ["{{base_url}}"],
              "path": ["queue", "{{file_id}}", "update"]
            },
            "description": "Update markdown content. Recomputes content hash. Preserves current status."
          }
        }
      ]
    },
    {
      "name": "Files",
      "item": [
        {
          "name": "List All Files",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/files?page=1&size=20",
              "host": ["{{base_url}}"],
              "path": ["files"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "size", "value": "20" },
                { "key": "status", "value": "", "disabled": true },
                { "key": "region", "value": "", "disabled": true },
                { "key": "brand", "value": "", "disabled": true },
                { "key": "content_type", "value": "", "disabled": true },
                { "key": "component_type", "value": "", "disabled": true }
              ]
            },
            "description": "List all tracked files with optional filters. Enable query params to filter by status, region, brand, etc."
          }
        },
        {
          "name": "Get File Detail",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/files/{{file_id}}",
              "host": ["{{base_url}}"],
              "path": ["files", "{{file_id}}"]
            },
            "description": "Get full details for any tracked file."
          }
        }
      ]
    }
  ]
}