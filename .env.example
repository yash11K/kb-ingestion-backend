# =============================================================================
# AEM Knowledge Base Ingestion System — Environment Variables
# =============================================================================
# Copy this file to .env.dev or .env.preprod and fill in real values.
# Required variables are uncommented; optional ones show their defaults.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (required)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# -----------------------------------------------------------------------------
# AWS (required)
# -----------------------------------------------------------------------------
S3_BUCKET_NAME=my-bucket-name
# AWS_REGION=us-east-1

# -----------------------------------------------------------------------------
# Bedrock
# -----------------------------------------------------------------------------
# BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-20250514-v1:0
# BEDROCK_KB_ID=
# BEDROCK_MAX_TOKENS=16000

# -----------------------------------------------------------------------------
# Haiku discovery agent
# -----------------------------------------------------------------------------
# HAIKU_MODEL_ID=us.anthropic.claude-3-5-haiku-20241022-v1:0
# ENABLE_HAIKU_DISCOVERY=true
# HAIKU_MAX_INPUT_TOKENS=150000

# -----------------------------------------------------------------------------
# AEM
# -----------------------------------------------------------------------------
# AEM_REQUEST_TIMEOUT=30

# -----------------------------------------------------------------------------
# Validation thresholds
# -----------------------------------------------------------------------------
# AUTO_APPROVE_THRESHOLD=0.7
# AUTO_REJECT_THRESHOLD=0.2

# -----------------------------------------------------------------------------
# Processing limits
# -----------------------------------------------------------------------------
# MAX_PAYLOAD_BYTES=500000
# BATCH_THRESHOLD=8
# MAX_CONCURRENT_JOBS=3

# -----------------------------------------------------------------------------
# Component filtering
# -----------------------------------------------------------------------------
# ALLOWLIST=
# DENYLIST=

# -----------------------------------------------------------------------------
# URL / namespace filtering (comma-separated or JSON)
# -----------------------------------------------------------------------------
# URL_DENYLIST_PATTERNS=/reservation,/login,/account,/search,/booking,/checkout,/payment,/registration,/reset-password,/demo
# NAMESPACE_LIST=locations,products-and-services,protections-and-coverages,rental-addons,long-term-car-rental,one-way-car-rentals,miles-points-and-partners,meetings-and-groups,car-sales,faq,customer-service,travel-guides

# -----------------------------------------------------------------------------
# Locale / region mapping (JSON object)
# -----------------------------------------------------------------------------
# LOCALE_REGION_MAP={"en":"nam","en-us":"nam","en-ca":"nam","en-gb":"emea","en-ie":"emea","de":"emea","fr":"emea","en-au":"apac","en-nz":"apac"}
